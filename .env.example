# Copy this file to .env and fill in your own values.
# .env is gitignored — it never gets committed.

# Required for /api/skills/execute and the LLM routing fallback.
# Without it, execution returns 503 and routing stays keyword-only.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — overrides the default runtime model (claude-haiku-4-5).
# FABLE5_LLM_MODEL=claude-haiku-4-5
